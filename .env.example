# ============================================================
# Menu-to-Video Platform — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# cp .env.example apps/web/.env.local
# ⚠️  ห้าม commit .env.local เด็ดขาด!
# ============================================================

# ------------------------------------------------------------
# SUPABASE (https://supabase.com)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# OPENAI (https://platform.openai.com)
# ใช้สำหรับ: GPT-4o caption/script generation
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# ------------------------------------------------------------
# ANTHROPIC / CLAUDE (https://console.anthropic.com)
# ใช้สำหรับ: complex content tasks
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# FAL.AI (https://fal.ai) — Image Generation (Flux Pro)
# ใช้สำหรับ: text-to-image, image enhancement
# ------------------------------------------------------------
FAL_KEY=...

# ------------------------------------------------------------
# KLING AI (https://klingai.com/api) — Video Generation Tier 2
# ใช้สำหรับ: AI video จากรูปอาหาร
# ------------------------------------------------------------
KLING_API_KEY=...
KLING_API_SECRET=...

# ------------------------------------------------------------
# RUNWAY ML (https://runwayml.com) — Video Generation Tier 3
# ใช้สำหรับ: cinematic premium video
# ------------------------------------------------------------
RUNWAY_API_KEY=...

# ------------------------------------------------------------
# CREATOMATE (https://creatomate.com) — Video Generation Tier 1
# ใช้สำหรับ: template-based fast video (~10 sec)
# ------------------------------------------------------------
CREATOMATE_API_KEY=...

# ------------------------------------------------------------
# ELEVENLABS (https://elevenlabs.io) — Thai TTS
# ใช้สำหรับ: voiceover ภาษาไทย
# ------------------------------------------------------------
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID_TH=...

# ------------------------------------------------------------
# CLOUDFLARE R2 — File Storage
# ใช้สำหรับ: เก็บ video/image files
# ------------------------------------------------------------
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=kaizen-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ------------------------------------------------------------
# LINE OA (https://developers.line.biz)
# ใช้สำหรับ: LINE chatbot + broadcast
# ------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=...
LINE_CHANNEL_SECRET=...

# ------------------------------------------------------------
# TELEGRAM BOT (https://t.me/BotFather)
# ใช้สำหรับ: owner alerts + customer bot
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=...
TELEGRAM_OWNER_CHAT_ID=...

# ------------------------------------------------------------
# REDIS — Job Queue
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# N8N
# ------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=...

# ------------------------------------------------------------
# POSTGRES (local dev)
# ------------------------------------------------------------
DATABASE_URL=postgresql://kaizen:kaizen_secret@localhost:5432/kaizen

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# SOCIAL MEDIA APIs (Phase 5)
# ------------------------------------------------------------
# TikTok
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
# Facebook / Instagram
META_APP_ID=...
META_APP_SECRET=...
META_PAGE_ACCESS_TOKEN=...
# YouTube
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...
