# ============================================================
# Menu-to-Video Platform — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# cp .env.example apps/web/.env.local
# ⚠️  ห้าม commit .env.local เด็ดขาด!
# ============================================================

# ------------------------------------------------------------
# SUPABASE (https://supabase.com)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# BASIC AUTH — ป้องกันทั้ง dashboard และ API (จำเป็นก่อน deploy!)
# ------------------------------------------------------------
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=เปลี่ยนรหัสนี้ก่อน_deploy

# ------------------------------------------------------------
# PHAYA.IO (https://phaya.io) — Video Provider หลัก (ตัวเดียวที่จำเป็น)
# Image-to-Video FFmpeg (tier1) / Sora 2 (tier2-3) / TTS / Merge Audio-Video
# ------------------------------------------------------------
PHAYA_API_KEY=...

# ------------------------------------------------------------
# TTS — เสียงพากย์ลงคลิป (ปิดไว้ก่อนใน MVP — เปิดเมื่อพร้อมเทสต์)
# ------------------------------------------------------------
ENABLE_TTS=false

# ------------------------------------------------------------
# OPENAI (https://platform.openai.com)
# ใช้สำหรับ: GPT-4o caption/script generation
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# ------------------------------------------------------------
# ANTHROPIC / CLAUDE (https://console.anthropic.com)
# ใช้สำหรับ: complex content tasks
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# FAL.AI (https://fal.ai) — Image Generation (Flux Pro)
# ใช้สำหรับ: text-to-image, image enhancement
# ------------------------------------------------------------
FAL_KEY=...

# ------------------------------------------------------------
# KLING AI — [OPTIONAL/ไม่ใช้แล้ว] ถูกถอดออกจาก pipeline (ดู CHANGES.md)
# ใช้สำหรับ: AI video จากรูปอาหาร
# ------------------------------------------------------------
KLING_API_KEY=...
KLING_API_SECRET=...

# ------------------------------------------------------------
# RUNWAY ML — [OPTIONAL/ไม่ใช้แล้ว] ถูกถอดออกจาก pipeline (ดู CHANGES.md)
# ใช้สำหรับ: cinematic premium video
# ------------------------------------------------------------
RUNWAY_API_KEY=...

# ------------------------------------------------------------
# CREATOMATE — [OPTIONAL] fallback เท่านั้น ไม่ตั้งก็ได้ (แพง $54+/เดือน)
# ใช้สำหรับ: template-based fast video (~10 sec)
# ------------------------------------------------------------
CREATOMATE_API_KEY=...

# ------------------------------------------------------------
# ELEVENLABS — [OPTIONAL] ใช้เฉพาะถ้าไม่มี PHAYA_API_KEY และเปิด ENABLE_TTS
# ใช้สำหรับ: voiceover ภาษาไทย
# ------------------------------------------------------------
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID_TH=...

# ------------------------------------------------------------
# STORAGE — ใช้ Supabase Storage (bucket "media") อัตโนมัติ
# ไม่ต้องตั้งค่าอะไรเพิ่ม — ใช้ SUPABASE_* ด้านบน
# ------------------------------------------------------------
STORAGE_BUCKET=media

# ------------------------------------------------------------
# LINE OA (https://developers.line.biz)
# ใช้สำหรับ: LINE chatbot + broadcast
# ------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=...
LINE_CHANNEL_SECRET=...

# ------------------------------------------------------------
# TELEGRAM BOT (https://t.me/BotFather)
# ใช้สำหรับ: owner alerts + customer bot
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=...
TELEGRAM_OWNER_CHAT_ID=...

# ------------------------------------------------------------
# REDIS — Job Queue
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# N8N
# ------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5679/webhook
N8N_API_KEY=...

# ------------------------------------------------------------
# POSTGRES (local dev)
# ------------------------------------------------------------
DATABASE_URL=postgresql://kaizen:kaizen_secret@localhost:5432/kaizen

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# SOCIAL MEDIA APIs (Phase 5)
# ------------------------------------------------------------
# TikTok
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
# Facebook / Instagram
META_APP_ID=...
META_APP_SECRET=...
META_PAGE_ACCESS_TOKEN=...
# YouTube
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REFRESH_TOKEN=...
